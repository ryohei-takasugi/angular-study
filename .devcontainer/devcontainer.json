{
    "name": "Angular Latest Dev Environment",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "angular-dev",
    "workspaceFolder": "/workspaces/angular-study",
    "customizations": {
        "vscode": {
            "extensions": [
                "Angular.ng-template",
                "editorconfig.editorconfig",
                "esbenp.prettier-vscode"
            ]
        }
    },
    "postCreateCommand": "npm install"
}
